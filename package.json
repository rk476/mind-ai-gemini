{
  "name": "mind-agent-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently -n next,worker -c blue,green \"next dev\" \"tsx worker/worker.ts\"",
    "build": "next build",
    "start": "next start",
    "start:all": "concurrently -n next,worker -c blue,green \"next start\" \"tsx worker/worker.ts\"",
    "lint": "next lint",
    "worker": "tsx worker/worker.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx lib/db/migrate.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@google/genai": "^1.45.0",
    "@google/generative-ai": "^0.24.1",
    "bullmq": "^5.12.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.36.0",
    "ioredis": "^5.4.0",
    "mongodb": "^7.1.0",
    "nanoid": "^5.0.7",
    "next": "^14.2.0",
    "pino": "^9.3.0",
    "playwright": "^1.45.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
